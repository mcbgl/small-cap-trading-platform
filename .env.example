# =============================================================================
# Small-Cap Trading Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# When running outside Docker, use localhost.
# Docker Compose overrides these to use service names automatically.
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading
QUESTDB_URL=http://localhost:9000
QUESTDB_ILP_HOST=localhost:9009

# -----------------------------------------------------------------------------
# Cache / Message Broker
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Local LLM (Ollama - optional)
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Market Data - Polygon.io
# Get your key at: https://polygon.io/dashboard/signup
# -----------------------------------------------------------------------------
POLYGON_API_KEY=your_polygon_key_here

# -----------------------------------------------------------------------------
# AI - Anthropic Claude
# Get your key at: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here

# -----------------------------------------------------------------------------
# Broker - Alpaca (paper trading by default)
# Get your keys at: https://app.alpaca.markets/paper/dashboard/overview
# -----------------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# -----------------------------------------------------------------------------
# SEC EDGAR - Required user agent for API access
# Format: "YourName your@email.com"
# See: https://www.sec.gov/os/accessing-edgar-data
# -----------------------------------------------------------------------------
EDGAR_USER_AGENT=YourName your@email.com

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
PAPER_MODE=true
LOG_LEVEL=INFO
